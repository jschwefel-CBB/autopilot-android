<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!--
      The agent drives arbitrary installed apps (e.g. ScopeDOPE) via the external-plan
      entry point. On Android 11+ (API 30+), package visibility filtering hides other
      packages, so getLaunchIntentForPackage() returns null even when the app is
      installed. A test-automation agent legitimately needs to see and launch any app.
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.AppCompat.Light">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- Compose test fixture (reproduces the OutlinedTextField-in-AlertDialog
             find-after-type case under the CI gate). Launched directly by the
             instrumented test; not a launcher activity. -->
        <activity
            android:name=".ComposeFixtureActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />
    </application>
</manifest>
